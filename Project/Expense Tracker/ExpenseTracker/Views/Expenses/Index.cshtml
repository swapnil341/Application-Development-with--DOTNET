@model IEnumerable<ExpenseTracker.Models.Expense>

@{
    ViewData["Title"] = "Expenses";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">
            <i class="bi bi-wallet2 me-2"></i>Expense Tracker
        </h2>
        <a asp-action="Create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i> Add New Expense
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No expenses recorded yet. Click <strong>Add New Expense</strong> to get started.
        </div>
    }
    else
    {
        <!-- Summary Card -->
        <div class="card mb-4 border-0 shadow-sm">
            <div class="card-body d-flex justify-content-between align-items-center">
                <div>
                    <span class="text-muted">Total Expenses</span>
                    <h4 class="mb-0 text-danger fw-bold">
                        @Model.Sum(e => e.Amount).ToString("C")
                    </h4>
                </div>
                <div class="text-end">
                    <span class="text-muted">Records</span>
                    <h4 class="mb-0">@Model.Count()</h4>
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th scope="col">#</th>
                            <th scope="col">Description</th>
                            <th scope="col">Category</th>
                            <th scope="col">Date</th>
                            <th scope="col" class="text-end">Amount</th>
                            <th scope="col" class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int row = 1; }
                        @foreach (var expense in Model)
                        {
                            <tr>
                                <td class="text-muted">@row++</td>
                                <td>@expense.Description</td>
                                <td>
                                    <span class="badge bg-secondary">@expense.Category</span>
                                </td>
                                <td>@expense.Date.ToString("MMM dd, yyyy")</td>
                                <td class="text-end fw-semibold text-danger">
                                    @expense.Amount.ToString("C")
                                </td>
                                <td class="text-center">
                                    <form asp-action="Delete" asp-route-id="@expense.Id" method="post"
                                          onsubmit="return confirm('Are you sure you want to delete this expense?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash me-1"></i>Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="4" class="text-end fw-bold">Grand Total:</td>
                            <td class="text-end fw-bold text-danger fs-6">
                                @Model.Sum(e => e.Amount).ToString("C")
                            </td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    }
</div>